# Magellan — variables d'environnement.
# Copier en .env.local et remplir au moment du branchement (Étape 0 du cahier des charges).

# --- Supabase (base, auth, storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Clé service role : NE JAMAIS exposer côté client. Utilisée par le serveur MCP et les jobs serveur.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (restreint aux domaines stefani.fr et collision.studio) ---
# Configuré dans Supabase Auth > Providers > Google. Domaines vérifiés côté app.
GOOGLE_OAUTH_ALLOWED_DOMAINS=stefani.fr,collision.studio

# --- Connecteur MCP (dialoguer avec Magellan depuis l'app Claude) ---
# Secret de signature des jetons OAuth du connecteur. Si absent, SUPABASE_SERVICE_ROLE_KEY est utilisé.
MCP_OAUTH_SECRET=

# --- IA (copilote, vision pour captures, veille) ---
# Sans clé : le copilote tourne en mode démo (heuristique sur données locales).
ANTHROPIC_API_KEY=your-anthropic-key
# Modèle du copilote (défaut : claude-opus-4-8). Mettre claude-sonnet-4-6 pour réduire le coût.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Folk (import du CRM existant, pipe invité — §14.2) ---
# Clé API créée dans Folk > Settings > Developer/API. Serveur uniquement (pas NEXT_PUBLIC).
FOLK_API_KEY=your-folk-api-key

# --- Figma (récupération des tokens identité au build) ---
FIGMA_FILE_ID=ZI56QbnEsPRDjL5JXJ7oEz

# --- App ---
NEXT_PUBLIC_APP_NAME=Magellan
NEXT_PUBLIC_SITE_URL=http://localhost:3000
